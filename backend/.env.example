# DeepSeek API (兼容 OpenAI 接口)
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 数据库（本地相对路径或绝对路径）
DATABASE_URL=sqlite:///./news_aggregator.db

# 定时任务：新闻抓取+AI处理间隔（小时），默认4小时
UPDATE_INTERVAL_HOURS=4

# HTTP 代理（用于访问 Google API）
# 格式: http://127.0.0.1:7890
HTTP_PROXY=

# Gmail API OAuth 凭证（从 Google Cloud Console 获取）
# 在 https://console.cloud.google.com/apis/credentials 创建 OAuth 桌面客户端
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# 邮箱账号（可配置多个，用逗号分隔）
# IMAP格式: email:auth_code:imap_server:imap_port
# Gmail API格式(推荐): email:gmail_api:::
# 示例: user@gmail.com:gmail_api:::,user@qq.com:authcode:imap.qq.com:993
EMAIL_ACCOUNTS=
